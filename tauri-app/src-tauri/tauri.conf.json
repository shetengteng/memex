{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Memex",
  "version": "0.3.4",
  "identifier": "ttshe.memex",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1520",
    "beforeBuildCommand": "npm run build && npm run prepare-sidecars",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Memex",
        "width": 1100,
        "height": 720,
        "minWidth": 880,
        "minHeight": 560,
        "visible": false,
        "decorations": true,
        "transparent": false,
        "shadow": true,
        "resizable": true,
        "skipTaskbar": false,
        "alwaysOnTop": false,
        "center": true
      },
      {
        "label": "tray-popup",
        "title": "Memex Tray",
        "url": "index.html#/tray-popup",
        "width": 360,
        "height": 520,
        "visible": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "backgroundColor": "#00000000",
        "resizable": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "focus": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "memex"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "app"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/memex-daemon",
      "binaries/memex"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-",
      "entitlements": "entitlements.plist"
    }
  }
}
